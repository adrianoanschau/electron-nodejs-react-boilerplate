{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/core/*": ["./src/core/*"],
      "@/main/*": ["./src/main/*"],
      "@/renderer/*": ["./src/renderer/*"]
    },
    "lib": ["DOM", "ESNext"],
    "types": ["vite/client", "vitest/globals"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
}